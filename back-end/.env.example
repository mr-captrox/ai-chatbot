# Environment Variables Template
# Copy this file to .env and fill in your keys

# Groq API Key (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Google API Key (Shared for Gemini and CSE)
GOOGLE_API_KEY=your_google_api_key_here

# Google Gemini API Key (Optional if GOOGLE_API_KEY is set)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Google Custom Search Engine (CSE) ID
GOOGLE_CSE_ID=your_google_cse_id_here

# Google Custom Search API Key (Optional if GOOGLE_API_KEY is set)
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here

# Tavily API Key (Alternative for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith API Key (Optional)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT_NAME=chatbot-project

# LLM Configuration
LLM_MODEL_NAME=llama-3.1-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Vector Database
VECTOR_DB_PATH=./data/vector_store

# FastAPI Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Streamlit Configuration
STREAMLIT_API_URL=http://localhost:8000
